<?xml version="1.0"?>
<sdf version='1.10'>
  <world name='dual_chinook_world'>
    <gravity>0 0 -9.80665</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic' />
    <wind />
    <physics name='default_physics' type='gz-physics6'>
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>500</real_time_update_rate>
    </physics>

    <model name='ground_plane'>
      <static>true</static>
      <link name='ground_link'>
        <collision name='ground_collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='ground_visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <light name='sun' type='directional'>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>1000</range>
        <linear>0.01</linear>
        <constant>0.8</constant>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.5 -1</direction>
      <cast_shadows>true</cast_shadows>
    </light>

    <model name='dual_chinook'>
      <pose>0 0 0.35 0 0 0</pose>
      <static>false</static>

      <link name='base_link'>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>8.0</mass>
          <inertia>
            <ixx>1.6</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>2.7333</iyy>
            <iyz>0</iyz>
            <izz>2.1333</izz>
          </inertia>
        </inertial>
        <collision name='base_collision'>
          <pose>0 0 -0.35 0 0 0</pose>
          <geometry>
            <box>
              <size>0.4 0.2 0.2</size>
            </box>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>100000</kp>
                <kd>1</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name='base_visual'>
          <pose>0 0 -0.35 0 0 0</pose>
          <geometry>
            <box>
              <size>0.4 0.2 0.2</size>
            </box>
          </geometry>
          <material>
            <ambient>0.23 0.23 0.23 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
      </link>

      <link name='mast_forward'>
        <pose>-1.0 0.0 0.35 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.01</ixx>
            <iyy>0.01</iyy>
            <izz>0.01</izz>
          </inertia>
        </inertial>
        <visual name='mast_forward_visual'>
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.4</length>
            </cylinder>
          </geometry>
        </visual>
      </link>

      <link name='mast_aft'>
        <pose>1.0 0.0 0.35 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.01</ixx>
            <iyy>0.01</iyy>
            <izz>0.01</izz>
          </inertia>
        </inertial>
        <visual name='mast_aft_visual'>
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.4</length>
            </cylinder>
          </geometry>
        </visual>
      </link>

      <link name='rotor_0'>
        <pose>-1.0 0.0 0.75 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>9.75e-05</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <collision name='rotor_0_collision'>
          <geometry>
            <cylinder>
              <radius>0.39</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name='rotor_0_visual'>
          <geometry>
            <cylinder>
              <radius>0.39</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.0 0.2 0.7 1</ambient>
            <diffuse>0.1 0.3 0.9 1</diffuse>
          </material>
        </visual>
      </link>

      <link name='rotor_1'>
        <pose>1.0 0.0 0.75 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>9.75e-05</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <collision name='rotor_1_collision'>
          <geometry>
            <cylinder>
              <radius>0.39</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name='rotor_1_visual'>
          <geometry>
            <cylinder>
              <radius>0.39</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.7 0.2 0.0 1</ambient>
            <diffuse>0.9 0.3 0.1 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name='mast_forward_joint' type='fixed'>
        <parent>base_link</parent>
        <child>mast_forward</child>
      </joint>

      <joint name='mast_aft_joint' type='fixed'>
        <parent>base_link</parent>
        <child>mast_aft</child>
      </joint>

      <joint name='rotor_0_joint' type='revolute'>
        <parent>mast_forward</parent>
        <child>rotor_0</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1e16</lower>
            <upper>1e16</upper>
          </limit>
          <dynamics>
            <damping>0</damping>
          </dynamics>
        </axis>
      </joint>

      <joint name='rotor_1_joint' type='revolute'>
        <parent>mast_aft</parent>
        <child>rotor_1</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1e16</lower>
            <upper>1e16</upper>
          </limit>
          <dynamics>
            <damping>0</damping>
          </dynamics>
        </axis>
      </joint>

      <plugin filename="gz-sim-multicopter-motor-model-system"
        name="gz::sim::systems::MulticopterMotorModel">
        <jointName>rotor_0_joint</jointName>
        <linkName>rotor_0</linkName>
        <turningDirection>ccw</turningDirection>
        <timeConstantUp>0.15</timeConstantUp>
        <timeConstantDown>0.25</timeConstantDown>
        <maxRotVelocity>1600.0</maxRotVelocity>
        <motorConstant>6.4e-05</motorConstant>
        <momentConstant>0.02</momentConstant>
        <commandSubTopic>command/motor_speed</commandSubTopic>
        <motorNumber>0</motorNumber>
        <rotorDragCoefficient>8.0e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>1.0e-06</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>1.0</rotorVelocitySlowdownSim>
        <motorType>velocity</motorType>
      </plugin>

      <plugin filename="gz-sim-multicopter-motor-model-system"
        name="gz::sim::systems::MulticopterMotorModel">
        <jointName>rotor_1_joint</jointName>
        <linkName>rotor_1</linkName>
        <turningDirection>cw</turningDirection>
        <timeConstantUp>0.15</timeConstantUp>
        <timeConstantDown>0.25</timeConstantDown>
        <maxRotVelocity>1600.0</maxRotVelocity>
        <motorConstant>6.4e-05</motorConstant>
        <momentConstant>0.02</momentConstant>
        <commandSubTopic>command/motor_speed</commandSubTopic>
        <motorNumber>1</motorNumber>
        <rotorDragCoefficient>8.0e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>1.0e-06</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>1.0</rotorVelocitySlowdownSim>
        <motorType>velocity</motorType>
      </plugin>

      <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
        <parent_link>base_link</parent_link>
        <topic>/world/dual_chinook_world/model/dual_chinook/imu</topic>
        <gravity_dir_x>0</gravity_dir_x>
        <gravity_dir_y>0</gravity_dir_y>
        <gravity_dir_z>-1</gravity_dir_z>
      </plugin>
    </model>
  </world>
</sdf>
